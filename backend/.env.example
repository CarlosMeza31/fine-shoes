# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a Git — agrégalo a .gitignore

# --- Base de datos ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fine_shoes
DB_USER=root
DB_PASSWORD=tu_password_aqui

# --- JWT ---
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440   # 24 horas

# --- Servidor ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5500   # URL donde corre tu frontend (Live Server de VS Code)
